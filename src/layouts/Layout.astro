---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "우리 부부의 여행 아카이브" } = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title} · 여행 아카이브</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Song+Myung&family=Gaegu:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="shell">
      <header class="site-header">
        <a class="brand" href={import.meta.env.BASE_URL}>✈️ 우리 여행 이야기</a>
      </header>
      <main>
        <slot />
      </main>
    </div>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light dark;
    --bg: #faf3e8;
    --paper: #fffdf9;
    --fg: #3a2f28;
    --muted: #8a7b6d;
    --border: #e9dcc6;
    --accent: #c9704a;
    --tape: rgba(255, 214, 120, 0.6);
    font-family: -apple-system, "Pretendard", "Apple SD Gothic Neo", "Noto Sans KR", sans-serif;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #211a12;
      --paper: #2a2118;
      --fg: #f1e6d8;
      --muted: #b3a290;
      --border: #40342a;
      --tape: rgba(255, 214, 120, 0.28);
    }
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--bg);
    background-image: radial-gradient(circle at 1px 1px, rgba(120, 100, 70, 0.08) 1px, transparent 0);
    background-size: 22px 22px;
    color: var(--fg);
    line-height: 1.6;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .shell {
    max-width: 780px;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
  }

  .site-header {
    padding: 2rem 0 1rem;
  }

  .brand {
    font-family: "Song Myung", serif;
    font-size: 1.3rem;
  }

  h1 {
    font-family: "Song Myung", serif;
    font-size: 2.2rem;
    font-weight: 400;
    margin: 0.5rem 0 0.25rem;
  }

  h2 {
    display: inline-block;
    font-family: "Gaegu", sans-serif;
    font-size: 1.3rem;
    font-weight: 700;
    margin: 2.8rem 0 1.2rem;
    color: var(--fg);
    position: relative;
  }

  h2::after {
    content: "";
    display: block;
    width: 110%;
    height: 0.5em;
    background: var(--tape);
    position: absolute;
    left: -5%;
    bottom: 0.05em;
    z-index: -1;
    transform: rotate(-1deg);
  }

  .tagline {
    font-family: "Gaegu", sans-serif;
    font-size: 1.05rem;
    color: var(--muted);
  }

  .card {
    display: block;
    background: var(--paper);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.9rem 0.9rem 1.2rem;
    margin-bottom: 1.8rem;
    box-shadow:
      0 8px 18px rgba(60, 40, 20, 0.14),
      0 1px 2px rgba(60, 40, 20, 0.08);
    position: relative;
    transform: rotate(-1.4deg);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .card:nth-child(2n) {
    transform: rotate(1.3deg);
  }

  .card:nth-child(3n) {
    transform: rotate(-0.7deg);
  }

  .card:hover {
    transform: rotate(0deg) scale(1.015);
    box-shadow:
      0 14px 26px rgba(60, 40, 20, 0.2),
      0 2px 4px rgba(60, 40, 20, 0.1);
  }

  .card::before {
    content: "";
    position: absolute;
    top: -11px;
    left: 50%;
    transform: translateX(-50%) rotate(-3deg);
    width: 64px;
    height: 22px;
    background: var(--tape);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
  }

  .card-photo {
    aspect-ratio: 16 / 10;
    border-radius: 2px;
    background: linear-gradient(135deg, #f1e3c8, #e6d2ac);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 5rem;
    margin-bottom: 0.8rem;
  }

  .card-title {
    font-family: "Song Myung", serif;
    font-size: 1.2rem;
    margin: 0 0 0.3rem;
  }

  .card-meta {
    font-size: 0.85rem;
    color: var(--muted);
  }

  .empty {
    color: var(--muted);
    font-size: 0.9rem;
    padding: 0.5rem 0 1rem;
    font-family: "Gaegu", sans-serif;
  }

  .tags {
    margin-top: 0.6rem;
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .tag {
    font-family: "Gaegu", sans-serif;
    font-size: 0.85rem;
    color: var(--accent);
    border: 1px dashed var(--accent);
    border-radius: 999px;
    padding: 0.1rem 0.7rem;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 1rem;
    color: var(--muted);
    font-family: "Gaegu", sans-serif;
    font-size: 1rem;
  }

  .checklist-links {
    margin-top: 1.5rem;
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .checklist-links a {
    background: var(--paper);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.4rem 1rem;
    font-size: 0.9rem;
    box-shadow: 0 2px 6px rgba(60, 40, 20, 0.1);
  }

  article.body {
    margin-top: 1.5rem;
    background: var(--paper);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.5rem 1.7rem;
    box-shadow: 0 6px 16px rgba(60, 40, 20, 0.1);
  }

  article.body h2 {
    font-size: 1.1rem;
    margin: 1.8rem 0 0.8rem;
  }

  article.body h2:first-child {
    margin-top: 0;
  }

  article.body :is(ul, ol) {
    padding-left: 1.3rem;
  }

  article.body li {
    margin: 0.3rem 0;
  }

  article.body input[type="checkbox"] {
    margin-right: 0.5rem;
  }

  article.body ul:has(li > input[type="checkbox"]) {
    list-style: none;
    padding-left: 0.2rem;
  }

  article.body table {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
    font-size: 0.9rem;
  }

  article.body th,
  article.body td {
    border: 1px solid var(--border);
    padding: 0.5rem 0.7rem;
    text-align: left;
  }

  article.body th {
    background: var(--bg);
    color: var(--muted);
    font-weight: 600;
  }
</style>
