---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "우리 부부의 여행 아카이브" } = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title} · Travelogue</title>
  </head>
  <body>
    <div class="shell">
      <header class="site-header">
        <a class="brand" href={import.meta.env.BASE_URL}>
          <svg class="brand-icon" viewBox="0 0 24 24"><path d="M2 16l20-7-7 20-3-8-8-3 8-2z"/></svg>
          Travelogue
        </a>
      </header>
      <main>
        <slot />
      </main>
    </div>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light dark;
    --bg: #ffffff;
    --surface: #ffffff;
    --ink: #222222;
    --muted: #717171;
    --accent: #f15b57;
    --accent-ink: #ffffff;
    --border: #ebebeb;
    --border-strong: #dddddd;
    --radius: 12px;
    --radius-lg: 16px;
    --shadow: 0 1px 2px rgba(34, 29, 23, 0.05);
    --shadow-hover: 0 2px 8px rgba(34, 29, 23, 0.09);
    --status-upcoming-bg: #fdecea;
    --status-upcoming-ink: #c23a36;
    --status-candidate-bg: #fbf0e4;
    --status-candidate-ink: #9a5b00;
    --status-done-bg: #ecf3ec;
    --status-done-ink: #3b7a45;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Pretendard", "Apple SD Gothic Neo",
      "Noto Sans KR", Roboto, Helvetica, Arial, sans-serif;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #191919;
      --surface: #191919;
      --ink: #f2f2f2;
      --muted: #9b9b9b;
      --accent: #ff5a72;
      --accent-ink: #191919;
      --border: #2c2c2c;
      --border-strong: #3a3a3a;
      --shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
      --shadow-hover: 0 2px 10px rgba(0, 0, 0, 0.4);
      --status-upcoming-bg: #4a2422;
      --status-upcoming-ink: #ff8a85;
      --status-candidate-bg: #3a2f1a;
      --status-candidate-ink: #e0b56b;
      --status-done-bg: #1f3322;
      --status-done-ink: #7fc98c;
    }
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--ink);
    line-height: 1.6;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  a:focus-visible,
  button:focus-visible,
  input:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 6px;
  }

  .shell {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 28px 5rem;
  }

  .site-header {
    padding: 22px 0 6px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 8px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .brand-icon {
    width: 20px;
    height: 20px;
    stroke: var(--accent);
    stroke-width: 2;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  h1 {
    font-size: clamp(1.9rem, 3.6vw, 2.6rem);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin: 1.6rem 0 0.3rem;
  }

  h2 {
    font-size: 1.2rem;
    font-weight: 700;
    margin: 2.4rem 0 1rem;
    color: var(--ink);
  }

  .tagline {
    font-size: 0.98rem;
    color: var(--muted);
    margin: 0 0 1.6rem;
  }

  /* ---------- trip / checklist card ---------- */
  .card {
    display: block;
    cursor: pointer;
    border-radius: var(--radius);
  }

  .card-photo {
    position: relative;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius);
    overflow: hidden;
    background: linear-gradient(155deg, #e4ddc9, #cfc4a4);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.6rem;
    border: 1px solid var(--border);
    transition: border-color 0.2s ease, transform 0.2s ease;
    margin-bottom: 10px;
  }

  .card:hover .card-photo {
    border-color: var(--border-strong);
    transform: translateY(-2px);
  }

  .card-title {
    font-size: 1.05rem;
    font-weight: 700;
    margin: 0 0 2px;
  }

  .card-meta {
    font-size: 0.85rem;
    color: var(--muted);
  }

  .empty {
    color: var(--muted);
    font-size: 0.92rem;
    padding: 0.5rem 0 1rem;
  }

  .tags {
    margin-top: 0.5rem;
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--muted);
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    padding: 0.15rem 0.65rem;
  }

  /* ---------- status badge ---------- */
  .badge {
    display: inline-flex;
    align-items: center;
    font-size: 0.72rem;
    font-weight: 700;
    padding: 3px 9px;
    border-radius: 999px;
  }

  .badge-upcoming {
    background: var(--status-upcoming-bg);
    color: var(--status-upcoming-ink);
  }

  .badge-candidate {
    background: var(--status-candidate-bg);
    color: var(--status-candidate-ink);
  }

  .badge-done {
    background: var(--status-done-bg);
    color: var(--status-done-ink);
  }

  /* ---------- detail page ---------- */
  .back-link {
    display: inline-block;
    margin-bottom: 0.5rem;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .checklist-links {
    margin-top: 1.4rem;
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .checklist-links a {
    background: var(--surface);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius);
    padding: 0.4rem 1rem;
    font-size: 0.88rem;
    font-weight: 600;
    transition: border-color 0.15s ease;
  }

  .checklist-links a:hover {
    border-color: var(--ink);
  }

  article.body {
    margin-top: 1.6rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.7rem 1.9rem;
    counter-reset: day;
  }

  article.body h2 {
    font-size: 1.15rem;
    margin: 1.8rem 0 0.8rem;
  }

  article.body h2:first-child {
    margin-top: 0;
  }

  article.body :is(ul, ol) {
    padding-left: 1.3rem;
  }

  article.body li {
    margin: 0.3rem 0;
  }

  article.body input[type="checkbox"] {
    margin-right: 0.5rem;
    accent-color: var(--accent);
  }

  article.body ul:has(li > input[type="checkbox"]) {
    list-style: none;
    padding-left: 0.2rem;
  }

  /* ---------- Day 타임라인 (동선/일정 안의 h3) ---------- */
  article.body h3 {
    counter-increment: day;
    position: relative;
    font-size: 0.95rem;
    font-weight: 700;
    padding-left: 2.1rem;
    margin: 1.6rem 0 0.6rem;
  }

  article.body h3::before {
    content: counter(day);
    position: absolute;
    left: 0;
    top: -1px;
    width: 1.7rem;
    height: 1.7rem;
    border-radius: 50%;
    background: var(--accent);
    color: var(--accent-ink);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight: 800;
  }

  article.body h3 + ul,
  article.body h3 + ul + p {
    margin-left: 0.75rem;
    padding-left: 1.3rem;
    border-left: 2px dashed var(--border-strong);
  }

  /* ---------- 가볼곳/먹을곳 후보: <ul class="candidates">로 명시한 리스트만 pill 그리드로 ---------- */
  article.body ul.candidates {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 8px;
    list-style: none;
    padding-left: 0;
  }

  article.body ul.candidates li {
    border: 1px solid var(--border-strong);
    border-radius: var(--radius);
    padding: 6px 14px;
    font-size: 0.85rem;
    margin: 0;
  }

  /* ---------- 예산 표: 마지막 행(합계)을 강조 ---------- */
  article.body table tr:last-child td {
    font-weight: 700;
    border-top: 2px solid var(--ink);
  }

  article.body table {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
    font-size: 0.9rem;
    font-variant-numeric: tabular-nums;
  }

  article.body th,
  article.body td {
    border: 1px solid var(--border);
    padding: 0.5rem 0.7rem;
    text-align: left;
  }

  article.body th {
    background: var(--bg);
    color: var(--muted);
    font-weight: 700;
  }

  article.body img {
    max-width: 100%;
    border-radius: var(--radius);
    display: block;
    margin: 0.8rem 0;
    border: 1px solid var(--border);
  }

  article.body p {
    margin: 0.6rem 0;
  }
</style>
