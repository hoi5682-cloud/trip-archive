---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "우리 부부의 여행 아카이브" } = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title} · 여행 아카이브</title>
  </head>
  <body>
    <div class="shell">
      <header class="site-header">
        <a class="brand" href={import.meta.env.BASE_URL}>✈️ 여행 아카이브</a>
      </header>
      <main>
        <slot />
      </main>
    </div>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light dark;
    --bg: #faf9f7;
    --fg: #1f1c1a;
    --muted: #6b6560;
    --card: #ffffff;
    --border: #e8e4de;
    --accent: #c9704a;
    font-family: -apple-system, "Pretendard", "Apple SD Gothic Neo", "Noto Sans KR", sans-serif;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #171513;
      --fg: #f1ede7;
      --muted: #a49d94;
      --card: #221f1c;
      --border: #35302b;
    }
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--fg);
    line-height: 1.6;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .shell {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
  }

  .site-header {
    padding: 2rem 0 1rem;
  }

  .brand {
    font-size: 1.1rem;
    font-weight: 700;
  }

  h1 {
    font-size: 1.9rem;
    margin: 0.5rem 0 0.25rem;
  }

  h2 {
    font-size: 1.2rem;
    margin: 2.5rem 0 1rem;
    color: var(--muted);
  }

  .card {
    display: block;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.1rem 1.3rem;
    margin-bottom: 0.8rem;
    transition: border-color 0.15s ease;
  }

  .card:hover {
    border-color: var(--accent);
  }

  .card-title {
    font-size: 1.05rem;
    font-weight: 600;
    margin: 0 0 0.3rem;
  }

  .card-meta {
    font-size: 0.85rem;
    color: var(--muted);
  }

  .empty {
    color: var(--muted);
    font-size: 0.9rem;
    padding: 0.5rem 0 1rem;
  }

  .tags {
    margin-top: 0.5rem;
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.75rem;
    color: var(--muted);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.15rem 0.6rem;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 1rem;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .checklist-links {
    margin-top: 1.5rem;
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .checklist-links a {
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.35rem 0.9rem;
    font-size: 0.85rem;
  }

  article.body {
    margin-top: 1.5rem;
  }

  article.body :is(ul, ol) {
    padding-left: 1.3rem;
  }

  article.body li {
    margin: 0.3rem 0;
  }

  article.body input[type="checkbox"] {
    margin-right: 0.5rem;
  }

  article.body ul:has(li > input[type="checkbox"]) {
    list-style: none;
    padding-left: 0.2rem;
  }

  article.body table {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
    font-size: 0.9rem;
  }

  article.body th,
  article.body td {
    border: 1px solid var(--border);
    padding: 0.5rem 0.7rem;
    text-align: left;
  }

  article.body th {
    background: var(--card);
    color: var(--muted);
    font-weight: 600;
  }
</style>
