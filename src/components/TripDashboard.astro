---
interface Props {
  sheet?: {
    itinerary?: string;
    budget?: string;
    checklist?: string;
  };
}

const { sheet } = Astro.props;
const hasAnySheet = !!(sheet && (sheet.itinerary || sheet.budget || sheet.checklist));
---

{
  hasAnySheet && (
    <div
      id="trip-dashboard"
      class="trip-dashboard"
      data-itinerary-url={sheet?.itinerary}
      data-budget-url={sheet?.budget}
      data-checklist-url={sheet?.checklist}
    >
      <div id="td-today" class="td-section">
        불러오는 중…
      </div>
      <div id="td-budget" class="td-section">
        불러오는 중…
      </div>
      {sheet?.itinerary && (
        <details class="td-details">
          <summary>전체 동선</summary>
          <div id="td-itinerary-full" />
        </details>
      )}
      {sheet?.checklist && (
        <details class="td-details">
          <summary>체크리스트 진행률</summary>
          <div id="td-checklist-full" />
        </details>
      )}
    </div>
  )
}

{
  hasAnySheet && (
    <script>
      import { mountTripDashboard } from "../lib/tripDashboard";
      const root = document.getElementById("trip-dashboard");
      if (root) mountTripDashboard(root);
    </script>
  )
}

<style>
  .trip-dashboard {
    display: flex;
    flex-direction: column;
    gap: 14px;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 16px 18px;
    background: var(--surface);
    margin: 20px 0;
  }

  .td-section h3 {
    margin: 0 0 8px;
    font-size: 0.95rem;
  }

  .td-item {
    display: flex;
    gap: 8px;
    align-items: baseline;
    font-size: 0.9rem;
    padding: 4px 0;
  }

  .td-time {
    font-weight: 700;
    color: var(--accent);
    white-space: nowrap;
  }

  .td-place {
    color: var(--muted);
    font-size: 0.82rem;
  }

  .td-muted {
    color: var(--muted);
    font-size: 0.85rem;
  }

  .td-error {
    color: var(--muted);
    font-size: 0.85rem;
    font-style: italic;
  }

  .td-bar {
    width: 100%;
    height: 8px;
    border-radius: 999px;
    background: var(--border);
    overflow: hidden;
  }

  .td-bar-fill {
    height: 100%;
    background: var(--accent);
  }

  .td-budget-line {
    margin: 8px 0 0;
    font-size: 0.85rem;
    color: var(--muted);
  }

  .td-details summary {
    cursor: pointer;
    font-weight: 700;
    font-size: 0.9rem;
  }

  .td-details[open] summary {
    margin-bottom: 8px;
  }
</style>
